APP_NAME="ASIP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_PORT=7801
APP_URL=http://localhost:7801
APP_TIMEZONE=Asia/Kolkata

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — PostgreSQL (via Docker)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=asip
DB_USERNAME=asip
DB_PASSWORD=secret

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# Cache / Queue / Broadcast
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

# Horizon
HORIZON_PREFIX=asip_horizon:

# File Storage — MinIO (S3-compatible, runs in Docker)
AWS_ACCESS_KEY_ID=asip
AWS_SECRET_ACCESS_KEY=secret123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=asip-uploads
AWS_ENDPOINT=http://minio:9000
# Browser-reachable endpoint used ONLY for generating presigned URLs (no network call)
AWS_PUBLIC_ENDPOINT=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# MinIO Config
MINIO_ROOT_USER=asip
MINIO_ROOT_PASSWORD=secret123
MINIO_BUCKETS=asip-uploads,asip-reports,asip-exports

# Mail — Mailhog (runs in Docker, caught at http://localhost:8025)
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@asip.local"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum SPA
SANCTUM_STATEFUL_DOMAINS=localhost:7801,localhost,127.0.0.1

# AI Providers
# NVIDIA Nemotron: reasoning model with thinking budget — primary for deep analysis
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NVIDIA_REASONING_BUDGET=16384
NVIDIA_ENABLE_THINKING=true

# Groq: fast LLM — fallback for quick responses
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Default provider: nvidia | groq | anthropic | openai
AI_DEFAULT_PROVIDER=nvidia

# Anthropic Claude: higher-quality reasoning (optional fallback)
ANTHROPIC_API_KEY=

# OpenAI: required for text embeddings (Sprint 7 RAG)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini: optional
GEMINI_API_KEY=

# Ollama: local embedding fallback (no API key needed)
OLLAMA_BASE_URL=http://host.docker.internal:11434

VITE_APP_NAME="${APP_NAME}"
SEO_WEBHOOK_TOKEN=generate_with_openssl_rand_hex_32
