# ─── ASIP production environment template ────────────────────────────────────
# Copy to .env on the production host and fill every <SET_ME>. Inject real
# secrets via your orchestrator's secret store where possible — never commit them.
# Use with: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build

APP_NAME="ASIP"
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false                   # MUST stay false (boot guard enforces this)
APP_URL=https://your-domain.com
APP_TIMEZONE=UTC                  # store/compute in UTC; convert at display

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Logging — stderr so `docker logs` / aggregation captures it; warning level
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Telescope must be absent in prod (dev dep); keep disabled regardless
TELESCOPE_ENABLED=false

# Database — managed Postgres with pgvector; migration role needs CREATE EXTENSION
DB_CONNECTION=pgsql
DB_HOST=<SET_ME>
DB_PORT=5432
DB_DATABASE=asip
DB_USERNAME=<SET_ME>
DB_PASSWORD=<SET_ME_STRONG>

# Session — secure cookies behind TLS
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3

# Queue retry must exceed the Horizon worker timeout (660) — see config/queue.php
REDIS_QUEUE_RETRY_AFTER=720

REDIS_CLIENT=phpredis
REDIS_HOST=<SET_ME>
REDIS_PASSWORD=<SET_ME_STRONG>
REDIS_PORT=6379

HORIZON_PREFIX=asip_horizon:

# Object storage (S3 or MinIO). PUBLIC endpoint must be browser/CDN-reachable.
AWS_ACCESS_KEY_ID=<SET_ME>
AWS_SECRET_ACCESS_KEY=<SET_ME>
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=asip-uploads
AWS_ENDPOINT=<SET_ME e.g. https://s3.region.amazonaws.com or internal MinIO URL>
AWS_PUBLIC_ENDPOINT=<SET_ME e.g. https://cdn.your-domain.com>
AWS_USE_PATH_STYLE_ENDPOINT=true
MINIO_ROOT_USER=<SET_ME>
MINIO_ROOT_PASSWORD=<SET_ME_STRONG>
MINIO_BUCKETS=asip-uploads,asip-reports,asip-exports

# Mail — real SMTP provider (MailHog is dev only)
MAIL_MAILER=smtp
MAIL_HOST=<SET_ME>
MAIL_PORT=587
MAIL_USERNAME=<SET_ME>
MAIL_PASSWORD=<SET_ME>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum SPA — your real domain(s) only
SANCTUM_STATEFUL_DOMAINS=your-domain.com

# AI providers — inject as secrets
AI_DEFAULT_PROVIDER=nvidia
NVIDIA_API_KEY=<SET_ME>
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NVIDIA_REASONING_BUDGET=16384
NVIDIA_ENABLE_THINKING=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                   # required for RAG embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

VITE_APP_NAME="${APP_NAME}"
# Generate: openssl rand -hex 32
SEO_WEBHOOK_TOKEN=<SET_ME>
